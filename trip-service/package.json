  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
